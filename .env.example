ADMIN_PIN=change_this_legacy_pin
ENABLE_LEGACY_ADMIN_PIN=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_login_password
WEB_AUTH_SECRET=change_this_to_32_chars_or_longer_random_secret
PORT=3333
VITE_API_BASE_URL=
SERVER_NODE_ENV=production
APP_ENV=lan
# true khi app chay sau reverse proxy/Cloudflare/Nginx de log IP client thuc tu header proxy.
TRUST_PROXY=false
ALLOWED_ORIGINS=http://localhost:3333,http://127.0.0.1:3333,http://172.25.20.208:3333,http://localhost:5173,http://127.0.0.1:5173
MAX_UPLOAD_MB=50
ACTIVITY_LOG_LIMIT=500
API_RATE_LIMIT_PER_MINUTE=300
AUTH_RATE_LIMIT_PER_MINUTE=20

# MHChub database riêng. Không dùng chung MYSQL_DATABASE=plc_monitoring của hệ IoT/PLC.
MHCHUB_MYSQL_HOST=127.0.0.1
MHCHUB_MYSQL_PORT=3308
MHCHUB_MYSQL_USER=root
MHCHUB_MYSQL_PASSWORD=
MHCHUB_MYSQL_DATABASE=mhchub
MHCHUB_MYSQL_CONNECTION_LIMIT=10
