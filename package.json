{
  "name": "company-utility-hub",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k --names WEB,API \"vite --host 0.0.0.0\" \"node server/index.js\"",
    "dev:web": "vite --host 0.0.0.0",
    "dev:api": "node server/index.js",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "node server/index.js",
    "build": "vite build --emptyOutDir=false && node scripts/audit-dist-assets.mjs --apply --strict-stale --quiet",
    "typecheck": "tsc --noEmit",
    "verify": "node scripts/run-quality-gates.mjs",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/index.js",
    "start:cluster": "node server/index.js",
    "mqtt:bridge": "node -e \"console.error('MHChub does not include an MQTT bridge. PLC/MQTT services are operated separately.'); process.exit(1)\"",
    "ops:health": "powershell -ExecutionPolicy Bypass -File scripts/utils/health-check.ps1",
    "ops:ports": "powershell -ExecutionPolicy Bypass -File scripts/verify-critical-ports.ps1",
    "ops:secrets": "powershell -ExecutionPolicy Bypass -File scripts/set-mhchub-secrets.ps1",
    "ops:startup": "powershell -ExecutionPolicy Bypass -File scripts/startup-guard.ps1",
    "ops:dist:cleanup-preview": "powershell -ExecutionPolicy Bypass -File scripts/clean-dist-stale-assets.ps1",
    "ops:service:check": "powershell -ExecutionPolicy Bypass -File setup/home-install/check-mhchub-service-windows.ps1",
    "ops:service:diagnose": "powershell -ExecutionPolicy Bypass -File setup/home-install/check-mhchub-service-windows.ps1 -Json -DiagnosticOnly",
    "ops:service:repair-preview": "powershell -ExecutionPolicy Bypass -File setup/home-install/repair-mhchub-service-recovery-windows.ps1",
    "ops:service:repair-apply": "powershell -ExecutionPolicy Bypass -File setup/home-install/repair-mhchub-service-recovery-windows.ps1 -Apply",
    "ops:preflight": "node scripts/ops-production-preflight.mjs",
    "deploy:restart": "powershell -ExecutionPolicy Bypass -File scripts/restart-mhchub-service.ps1",
    "audit:seo": "node scripts/audit-seo-geo-performance.mjs --url http://127.0.0.1:3333/ --out qa/reports/seo-geo-performance-audit.json",
    "audit:text-integrity": "node scripts/audit-text-integrity.mjs",
    "audit:theme-first-paint": "node scripts/audit-theme-first-paint.mjs",
    "audit:zoom-background": "node scripts/audit-zoom-background-stability.mjs",
    "audit:image-assets": "node scripts/audit-image-asset-quality.mjs",
    "audit:accessibility": "node scripts/audit-accessibility-usability.mjs",
    "audit:scroll-stability": "node scripts/audit-scroll-stability.mjs",
    "audit:css-cleanliness": "node scripts/audit-css-cleanliness.mjs",
    "audit:i18n": "node scripts/audit-i18n-coverage.mjs",
    "audit:data": "node scripts/audit-data-consistency.mjs",
    "audit:documents": "node scripts/audit-document-storage.mjs",
    "audit:document-title-normalization": "node scripts/normalize-existing-document-titles.mjs --check",
    "audit:document-display-ui": "node scripts/audit-document-display-ui.mjs",
    "audit:document-preview-browser": "node scripts/audit-document-preview-browser.mjs",
    "audit:bulletin-ui": "node scripts/audit-bulletin-ui.mjs",
    "audit:app-shell-ui": "node scripts/audit-app-shell-ui.mjs",
    "audit:home-carousel-ui": "node scripts/audit-home-carousel-ui.mjs",
    "audit:operations-preflight-ui": "node scripts/audit-operations-preflight-ui.mjs",
    "audit:live-api-runtime": "node scripts/audit-live-api-runtime-drift.mjs",
    "audit:current-source-api-runtime": "node scripts/audit-current-source-api-runtime.mjs",
    "audit:api-json-contract": "node scripts/audit-api-json-contract.mjs",
    "audit:safety-api": "node scripts/audit-safety-api-endpoints.mjs",
    "audit:safety-pages": "node scripts/audit-safety-page-routes.mjs",
    "audit:safety-interactions": "node scripts/audit-safety-interactions.mjs",
    "audit:ops": "node scripts/audit-ops-entrypoints.mjs",
    "audit:home-package": "node scripts/audit-home-install-package.mjs",
    "audit:dependencies": "node scripts/audit-dependencies.mjs",
    "audit:security-headers": "node scripts/audit-security-headers.mjs",
    "audit:no-runtime-jsx": "node scripts/audit-no-runtime-jsx.mjs",
    "audit:frontend-js-migration": "node scripts/audit-frontend-js-migration.mjs",
    "audit:dist-assets": "node scripts/audit-dist-assets.mjs --apply",
    "audit:admin-routes": "node scripts/audit-admin-route-access.mjs",
    "audit:runtime-backup": "node scripts/audit-runtime-backup.mjs",
    "audit:safety-source": "node scripts/audit-safety-meeting-source.mjs",
    "data:import-safety-documents": "node scripts/import-safety-documents.mjs",
    "data:ocr-safety-documents": "node scripts/ocr-safety-documents.mjs",
    "data:seed-safety-architecture-demo": "node scripts/seed-safety-architecture-demo-data.mjs",
    "data:backfill-i18n": "node scripts/backfill-i18n-content.mjs",
    "test:auth-roles": "node scripts/test-auth-role-access.mjs",
    "test:document-audit-console": "node scripts/test-document-audit-console-output.mjs",
    "test:document-display-title": "node scripts/test-document-display-title.mjs",
    "test:document-text-encoding": "node scripts/test-document-text-encoding.mjs",
    "test:document-upload-policy": "node scripts/test-document-upload-policy.mjs",
    "test:excel-html-format-regression": "node scripts/test-excel-html-format-regression.mjs",
    "test:excel-html-sanitizer": "node scripts/test-excel-html-sanitizer.mjs",
    "test:metadata-encoding": "node scripts/test-metadata-encoding.mjs --require-dist",
    "test:mirror": "node scripts/test-central-processor-mirror.mjs",
    "test:runtime-backup": "node scripts/test-runtime-supervisor-backup.mjs",
    "test:safety-source-baseline": "node scripts/test-safety-source-baseline-reject.mjs",
    "test:safety-source-console": "node scripts/test-safety-source-console-output.mjs",
    "test:xlsx-preview": "node scripts/test-xlsx-preview-merged-cells.mjs",
    "data:normalize-document-titles": "node scripts/normalize-existing-document-titles.mjs",
    "data:export-mysql": "node scripts/export-mysql-database.mjs",
    "auth:ensure-admin": "node scripts/ensure-admin-user.mjs",
    "auth:seed-employees": "node scripts/seed-employee-viewers.mjs",
    "package:system": "powershell -ExecutionPolicy Bypass -File package_system.ps1"
  },
  "dependencies": {
    "@napi-rs/canvas": "^1.0.0",
    "@radix-ui/react-dialog": "^1.1.16",
    "@radix-ui/react-select": "^2.3.0",
    "@radix-ui/react-slot": "^1.2.5",
    "@radix-ui/react-tabs": "^1.1.14",
    "@radix-ui/react-tooltip": "^1.2.9",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/react-query": "^5.101.0",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "compression": "^1.8.1",
    "concurrently": "^9.0.0",
    "cors": "^2.8.5",
    "express": "^5.0.0",
    "lucide-react": "^0.468.0",
    "multer": "^2.0.0",
    "mysql2": "^3.22.4",
    "pdfjs-dist": "^6.0.227",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-router-dom": "^7.0.0",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tesseract.js": "^7.0.0",
    "typescript": "^6.0.3",
    "word-extractor": "^1.0.4"
  },
  "devDependencies": {
    "playwright": "^1.61.0",
    "potrace": "^2.1.8",
    "vite": "^7.0.0"
  }
}
